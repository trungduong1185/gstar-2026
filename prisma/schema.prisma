generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Application {
  id                      String    @id
  submittedAt             DateTime
  fullName                String
  email                   String
  yearOfBirth             String
  country                 String
  currentStatus           String
  currentRole             String
  organization            String
  linkedin                String
  github                  String?
  aiExperience            String
  readinessSignals        Json
  proudProject            String    @default("")
  careerGoal              String    @default("")
  technicalChallenge      String    @default("")
  targetOrganizations     String    @default("")
  impactGoal              String    @default("")
  mathConcepts            Json      @default("[]")
  machineLearningConcepts Json      @default("[]")
  deepLearningConcepts    Json      @default("[]")
  nlpConcepts             Json      @default("[]")
  motivationReasons       Json      @default("[]")
  programGoals            String    @default("")
  preferredTestSlot       String    @default("")
  referralSource          String    @default("")
  motivation              String
  resumeFileName          String
  resumeSize              Int
  resumeStorage           String    @default("vps")
  resumePath              String?
  resumeUrl               String?
  googleSheetsSynced      Boolean   @default(false)
  scholarshipRequest      Boolean   @default(false)
  weeklyAvailability      Boolean   @default(false)
  consent                 Boolean   @default(false)
  attribution             Json
  status                  String    @default("Submitted")
  confirmationEmailStatus String    @default("not-configured")
  confirmationEmailSentAt DateTime?
  confirmationEmailError  String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([email, submittedAt])
  @@index([submittedAt])
  @@index([status])
}

model Mentor {
  id           String   @id
  name         String
  image        String
  alt          String
  group        String
  cohortStatus String
  category     String
  position     Json
  bio          String
  visible      Boolean  @default(true)
  social       Json
  sortOrder    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([group, sortOrder])
}

model ProgramSetting {
  id            Int      @id @default(1)
  cohortYear    Int
  timezone      String
  timezoneLabel String
  dates         Json
  updatedAt     DateTime @updatedAt
}

model IntegrationSetting {
  id                       Int      @id @default(1)
  googleSheetsEnabled      Boolean  @default(false)
  resumeStorage            String   @default("vps")
  googleSheetUrl           String   @default("")
  googleAppsScriptUrl      String   @default("")
  googleAppsScriptSecret   String   @default("")
  slackWebhookUrl          String   @default("")
  confirmationEmailEnabled Boolean  @default(false)
  smtpHost                 String   @default("")
  smtpPort                 Int      @default(587)
  smtpSecurity             String   @default("starttls")
  smtpUsername             String   @default("")
  smtpPassword             String   @default("")
  emailFromName            String   @default("GStar Bootcamp")
  emailFromAddress         String   @default("")
  emailReplyTo            String   @default("")
  gaMeasurementId         String   @default("")
  updatedAt               DateTime @updatedAt
}

model IdempotencyKey {
  key           String   @id
  applicationId String
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([expiresAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  displayName  String
  email        String    @unique
  passwordHash String
  role         String    @default("admin")
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([username])
  @@index([active])
}

model UtmLink {
  id          String   @id @default(cuid())
  label       String
  baseUrl     String   @default("https://summit.newturing.ai/gstar/")
  source      String
  medium      String
  campaign    String
  content     String   @default("")
  term        String   @default("")
  fullUrl     String
  shortCode   String?  @unique
  clicks      Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source, medium])
  @@index([campaign])
}
