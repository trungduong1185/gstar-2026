{
  "name": "gstar-next-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node scripts/start-standalone.mjs",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "lint": "prisma generate && tsc --noEmit",
    "check": "npm run lint && npm run build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:import": "tsx scripts/import-file-data.ts",
    "db:studio": "prisma studio",
    "install:production": "bash scripts/install-production-deps.sh",
    "postinstall": "prisma generate",
    "db:seed": "tsx scripts/seed-admin.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "prisma": "^7.8.0",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
