# Public site URL used for canonical, Open Graph, and structured data.
# Defaults to https://gstar.newturing.ai when unset.
NEXT_PUBLIC_SITE_URL=

# URL prefix when hosted in a subdirectory, for example /gstar. Leave blank at domain root.
NEXT_PUBLIC_BASE_PATH=

# GA4 Measurement ID used by the browser integration, for example G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional when Local VPS storage is selected in Admin. Deployed Google Apps Script Web App URL.
GOOGLE_APPS_SCRIPT_URL=

# Optional when Local VPS storage is selected. Must match the secret in Apps Script for Google storage.
GOOGLE_APPS_SCRIPT_SECRET=

# Required in production. Protects /dashboard with HTTP Basic Authentication.
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# Required in production. Use at least 32 random characters to sign admin sessions.
ADMIN_SESSION_SECRET=

# Optional. Slack (or Discord) incoming webhook URL. When set, /api/applications
# posts a summary to this webhook after each successful submission (fire-and-forget).
# Admin-saved value in /dashboard/settings overrides this env value.
SLACK_WEBHOOK_URL=

# --- Meta Conversions API (Sprint 2 · server-side conversion) ---
# Optional. When both META_PIXEL_ID and META_ACCESS_TOKEN are set, /api/applications
# fires a `Lead` event to Meta CAPI after each successful submission. Server-side
# events bypass ITP/ad-blockers so Advantage+ campaigns keep signal quality
# regardless of iOS 14+ tracking restrictions.
# The event_id matches the application ID so any pixel-side Lead is auto-deduped.
META_PIXEL_ID=
META_ACCESS_TOKEN=

# Optional. Only set while validating with Meta's "Test Events" tool.
# Leave blank in production so real events count for optimisation.
META_TEST_EVENT_CODE=
